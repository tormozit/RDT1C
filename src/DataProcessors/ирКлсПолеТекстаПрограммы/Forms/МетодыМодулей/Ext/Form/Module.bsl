	СтрокаПолногоОписания = МетодыМодуляВсе.Найти(ТекущаяСтрока.ПолноеИмя, "ПолноеИмя");
	ОткрытьОпределениеСтруктурыТипа(СтрокаПолногоОписания.ТаблицаТипов[0]);
	
