Перем мПолеТекстаХТМЛ;
Перем мФоновыйЗапросХттп;
Перем мНовыйКод; // Строка, Неопределено
Перем мНачальныйМаркерКода;
Перем мКонечныйМаркерКода;
Перем мМаркерПолногоКода;
Перем мНачальныйМаркерПатчей;
Перем мКонечныйМаркерПатчей;
//Перем мНачальныйМаркерЖСОН;
Перем мЧислоЗавершенныхБлоковКода;

Функция СохраняемаяНастройкаФормы(выхНаименование, выхИменаСвойств) Экспорт 
	выхИменаСвойств = "Форма.ТекстЗапроса, Форма.ПередаватьКонтекст, Форма.ВернутьТолькоКод, Форма.РазрешитьДозапросы";
	Возврат Неопределено;
КонецФункции

Процедура ЗагрузитьНастройкуВФорме(НастройкаФормы, ДопПараметры) Экспорт 
	ирКлиент.ЗагрузитьНастройкуФормыЛкс(ЭтаФорма, НастройкаФормы); 
КонецПроцедуры
 
Процедура ПриОткрытии()
	ирКлиент.Форма_ПриОткрытииЛкс(ЭтаФорма);
	мФоновыйЗапросХттп = ирКлиент.НовыйФоновыйЗапросХттпЛкс(ЭтаФорма);
	Если мФоновыйЗапросХттп.мБраузер = Неопределено Тогда
		ирОбщий.СообщитьЛкс("Требуется платформа 8.3.14+");
		Закрыть();
		Возврат;
	КонецЕсли;
	Если мПолеТекстаПрограммы = Неопределено Тогда
		мПолеТекстаПрограммы = ирКэш.ПолеТекстаПрограммы(0);
	КонецЕсли;
	мПолеТекстаХТМЛ = ирКлиент.ОболочкаПоляТекстаЛкс(ЭлементыФормы.Ответ);
	ТекстХТМЛ = ПолучитьМакет("ПросмотрMarkdownHTML").ПолучитьТекст();
	ТекстХТМЛ = СтрЗаменить(ТекстХТМЛ, "%ТекстJS%", ПолучитьМакет("ПросмотрMarkdownКод").ПолучитьТекст()); 
	ЭлементыФормы.Ответ.УстановитьТекст(ТекстХТМЛ);
	Если Истина
		И мПолеТекстаПрограммы.мМетодМодуля <> Неопределено 
		И мПолеТекстаПрограммы.мМетодМодуля.Имя <> "<>"
	Тогда
		ЭтаФорма.ИмяМетода = мПолеТекстаПрограммы.мМетодМодуля.Имя;
	КонецЕсли;
	ЭлементыФормы.ПолеКода.УстановитьТекст(КодЗапроса);
	ЭтаФорма.ИмяМодуля = мПолеТекстаПрограммы.мИмяМодуля;
	Если ПустаяСтрока(КодЗапроса) И ЗначениеЗаполнено(ИмяМетода) Тогда
		ЭлементыФормы.ПанельКонтекст.ТекущаяСтраница = ЭлементыФормы.ПанельКонтекст.Страницы.Метод;
	КонецЕсли;
	ЭлементыФормы.НадписьРазмер.Заголовок = "Размер: " + СтрДлина(мПолеТекстаПрограммы.мОригинальныйТекст) + " символов";
КонецПроцедуры

