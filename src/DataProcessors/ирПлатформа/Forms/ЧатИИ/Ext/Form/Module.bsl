Процедура Ответonclick(Элемент, pEvtObj)
	Если pEvtObj.srcElement.innerText = "Сравнить" Тогда
		ТекстБлокаКода = pEvtObj.srcElement.parentElement.parentElement.parentElement.childNodes[1].innerText;
		ирКлиент.Сравнить2ЗначенияВФормеЛкс(КодЗапроса, ТекстБлокаКода,, "Старый", "Новый",,,,, "ВстроенныйЯзык");
	КонецЕсли;
КонецПроцедуры

Процедура ДействияФормыПрименить(Кнопка = Неопределено)
	Если ЭлементыФормы.ПанельКонтекст.ТекущаяСтраница = ЭлементыФормы.ПанельКонтекст.Страницы.Модуль Тогда
		мПолеТекстаПрограммы.ВыделитьВесьТекст();
	ИначеЕсли ЭлементыФормы.ПанельКонтекст.ТекущаяСтраница = ЭлементыФормы.ПанельКонтекст.Страницы.Метод Тогда
		мПолеТекстаПрограммы.УстановитьГраницыВыделения(мПолеТекстаПрограммы.мМетодМодуля.ПозицияОпределения, мПолеТекстаПрограммы.мМетодМодуля.ПозицияОпределения + мПолеТекстаПрограммы.мМетодМодуля.ДлинаСОписанием);
	КонецЕсли;
	мПолеТекстаПрограммы.ВставитьНовыйВариантТекстаОтИИ(мНовыйКод);
	ЭлементыФормы.ДействияФормы.Кнопки.Применить.Доступность = Ложь;
	ЭлементыФормы.ДействияФормы.Кнопки.ПрименитьВыборочно.Доступность = Ложь;
	Если МодальныйРежим Тогда
		Закрыть(мНовыйКод);
	КонецЕсли;
КонецПроцедуры

Процедура ДействияФормыСыройОтвет(Кнопка)
	НовыйТекстОтвета = ирКлиент.ОткрытьТекстЛкс(ТекстОтвета, Заголовок, "Обычный",, КлючУникальности, ЭтаФорма,, Истина);
	Если НовыйТекстОтвета <> Неопределено Тогда
		Если Истина
			И Найти(НовыйТекстОтвета, "isInsert") = 0
			И Найти(НовыйТекстОтвета, мМаркерПолногоКода) = 0
		Тогда
			НовыйТекстОтвета = мМаркерПолногоКода + Символы.ПС + НовыйТекстОтвета;
		КонецЕсли;
		мНовыйКод = "";
		ОбновитьКодЗапроса();
		ЭтаФорма.ТекстОтвета = НовыйТекстОтвета;
		ОбработатьТекстОтвета(Истина);
	КонецЕсли;
КонецПроцедуры

