Функция ОбработатьОтвет(Форма) Экспорт
	Если Ложь
		Или мОписаниеЗадания = Неопределено
		Или мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.Отменено
	Тогда
		мОписаниеЗадания = Неопределено;
		Возврат "";
	КонецЕсли; 
	ТелоОтвета = СокрЛ(ПрочитатьЧастьОтвета());
	ЛиПотокЗавершен = Не мЛиПотоковый Или ЛиПотокЗавершен();
	ПрефиксЧастиОтвета = "data: ";
	Если Ложь
		Или ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, "Ошибка:") // парсер
		Или ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, "data: {""error""") // openAI
	Тогда
		мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно;
		ЛиПотокЗавершен = Истина;
	Иначе
		Если ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, "Отмена:") Тогда
			// Только для потокового режима
		ИначеЕсли ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, "Конец:") Тогда
			// Только для потокового режима
			ТелоОтвета = "";
		ИначеЕсли Ложь
			Или ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, ПрефиксЧастиОтвета)
			Или Найти(ТелоОтвета, Символы.ПС + ПрефиксЧастиОтвета)
		Тогда
			ТекстовыйДокумент = Новый ТекстовыйДокумент;
			ТекстовыйДокумент.УстановитьТекст(ТелоОтвета);
			Результат = Новый Массив;
			Для НомерСтроки = 1 По ТекстовыйДокумент.КоличествоСтрок() Цикл
				СтрокаТекста = ТекстовыйДокумент.ПолучитьСтроку(НомерСтроки);
				Если ирОбщий.СтрНачинаетсяСЛкс(СтрокаТекста, ПрефиксЧастиОтвета) Тогда
					ТекстБезПервогоФрагмента = ирОбщий.ТекстБезПервогоФрагментаЛкс(СтрокаТекста, ПрефиксЧастиОтвета);
					Если ТекстБезПервогоФрагмента = "[DONE]" Тогда
						// openAI
						//ЛиПотокЗавершен = Истина;
						Прервать;
					КонецЕсли;
					ЭлементСообщения = ирОбщий.ОбъектИзТекстаЖСОНЛкс(ТекстБезПервогоФрагмента);
					УИДСообщения = УИДСообщения(ЭлементСообщения);
					Если ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "content_delta") <> Неопределено Тогда
						// Напарник потоковый
						ВложеннаяЧасть = ЭлементСообщения.content_delta;
						Если ВложеннаяЧасть.Свойство("content") Тогда
							//ЧастьРазмышлений = ВложеннаяЧасть.reasoning;
							Результат.Добавить(ВложеннаяЧасть.content);
						КонецЕсли;
						Если ирОбщий.СвойствоСтруктурыЛкс(ВложеннаяЧасть, "tool_calls") <> Неопределено Тогда
							ПрочитатьЧастьДопзапросов(ВложеннаяЧасть);
						КонецЕсли;
						Если ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "finished") = Истина Тогда
							Если мНакопленныйДозапрос <> Неопределено Тогда
								// вызов инструментов — если ИИ вернул вызов инструмента, выполняем и продолжаем диалог
								Если ОбработатьВызовыИнструментов(мНакопленныйДозапрос, УИДСообщения) Тогда
									ЛиПотокЗавершен = Ложь;
									Результат.Очистить();
								КонецЕсли;
								мНакопленныйДозапрос = Неопределено;
							КонецЕсли;
						КонецЕсли;
					ИначеЕсли ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "content") <> Неопределено Тогда
						Если ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "finished") = Истина Тогда
							//ЛиПотокЗавершен = Истина;
						КонецЕсли;
					ИначеЕсли Истина
						И ЭлементСообщения.Свойство("choices") 
						И ЭлементСообщения.choices.Количество() > 0
					Тогда
						// openAI
						ВложеннаяЧасть = ЭлементСообщения.choices[0].delta;
						Если ВложеннаяЧасть.Свойство("content") Тогда
							//ЧастьРазмышлений = ВложеннаяЧасть.reasoning;
							Результат.Добавить(ВложеннаяЧасть.content);
						КонецЕсли;
						Если ВложеннаяЧасть.Свойство("tool_calls") Тогда
							ПрочитатьЧастьДопзапросов(ВложеннаяЧасть);
						КонецЕсли;
						Если Истина
							И мНакопленныйДозапрос <> Неопределено
							И ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения.choices[0], "finish_reason") = "tool_calls" 
						Тогда
							// вызов инструментов — если ИИ вернул вызов инструмента, выполняем и продолжаем диалог
							Если ОбработатьВызовыИнструментов(мНакопленныйДозапрос, УИДСообщения) Тогда
								ЛиПотокЗавершен = Ложь;
								Результат.Очистить();
							КонецЕсли;
							мНакопленныйДозапрос = Неопределено;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			ТелоОтвета = ирОбщий.СтрСоединитьЛкс(Результат, "");
			мНакопленныйОтвет = мНакопленныйОтвет + ТелоОтвета;
		Иначе
			Если ирОбщий.ЛиТекстJSONЛкс(ТелоОтвета) Тогда
				ОтветЖСОН = ирОбщий.ОбъектИзТекстаЖСОНЛкс(ТелоОтвета);
				Если Истина
					И ОтветЖСОН.Свойство("choices")
					И ОтветЖСОН.choices.Количество() > 0
				Тогда
					// openAI
					// вызов инструментов — если ИИ вернул вызов инструмента, выполняем и продолжаем диалог
					Если ОтветЖСОН.choices[0].message.Свойство("tool_calls") Тогда
						Если ОбработатьВызовыИнструментов(ОтветЖСОН.choices[0].message) Тогда
							ЛиПотокЗавершен = Ложь;
						КонецЕсли;
					КонецЕсли;
					мНакопленныйОтвет = ОтветЖСОН.choices[0].message.content; // Строка
				Иначе
					мНакопленныйОтвет = "";
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Если ЛиПотокЗавершен Тогда
			мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.Завершено;
		КонецЕсли;
	КонецЕсли; 
	мОписаниеЗадания.Параметры.Вставить("Ответ", мНакопленныйОтвет);
	Если ЛиПотокЗавершен Тогда
		Если мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
			Если мЛиПроверочный Тогда
				ирОбщий.СообщитьЛкс(ТелоОтвета,,,, Ложь);
			Иначе
				мОписаниеЗадания.Параметры.Ответ = мОписаниеЗадания.Параметры.Ответ + Символы.ПС + ТелоОтвета;
			КонецЕсли;
		КонецЕсли;
		ирКлиент.ОбработатьЗавершениеЗаданияФормыЛкс(мОписаниеЗадания, Форма,,,, мОписаниеЗадания.Параметры);
		Длительность = ТекущаяДата() - мОписаниеЗадания.НачалоВыполнения;
		Если Истина
			И Не мЛиПотоковый
			И (Ложь
				Или мЛиПроверочный И мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.Завершено
				Или мЛиПроверочный И Длительность > 1
				Или Длительность > 5)
		Тогда
			ирОбщий.СообщитьЛкс("ИИ ответил за " + Длительность + " секунд",,, Истина, Ложь);
		КонецЕсли;
		мОписаниеЗадания = Неопределено;
	ИначеЕсли мЛиПотоковый Тогда
		Если мОписаниеЗадания.ОбработчикЗавершения <> "" Тогда
			Состояние = мОписаниеЗадания.Состояние;
			Параметры = мОписаниеЗадания.Параметры;
			Выполнить("Форма." + мОписаниеЗадания.ОбработчикЗавершения + "(Состояние, Параметры)");
		КонецЕсли;
	КонецЕсли;
	Возврат мНакопленныйОтвет;
КонецФункции

//.
// Параметры:
//   ЭлементСообщения - Массив, Соответствие, Структура - 
// Возвращаемое значение:
//   Произвольный, Неопределено - 
Функция УИДСообщения(Знач ЭлементСообщения) Экспорт
	УИДСообщения = ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "uuid");
	Если ПустаяСтрока(УИДСообщения) Тогда
		УИДСообщения = ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "id");
	КонецЕсли;
	Возврат УИДСообщения;
КонецФункции

Процедура ПрочитатьЧастьДопзапросов(Знач ЧастьСообщения) Экспорт
	Если мНакопленныйДозапрос = Неопределено Тогда
		мНакопленныйДозапрос = ЧастьСообщения;
	Иначе
		Для Каждого ЧастьДозапроса Из ЧастьСообщения.tool_calls Цикл
			Если мНакопленныйДозапрос.tool_calls.ВГраница() < ЧастьДозапроса.index Тогда
				мНакопленныйДозапрос.tool_calls.Добавить(ЧастьДозапроса);
			КонецЕсли;
			мНакопленныйДозапрос.tool_calls[ЧастьДозапроса.index].function.arguments = мНакопленныйДозапрос.tool_calls[ЧастьДозапроса.index].function.arguments + ЧастьДозапроса.function.arguments;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

//.
// Параметры:
//   СообщениеИИ -  - 
//   ИсходноеСообщение - Строка, Массив - 
// Возвращаемое значение:
//    - 
Функция ОбработатьВызовыИнструментов(Знач СообщениеИИ, Знач УИДСообщения = "") Экспорт
	МаксВызовов = 20;
	Если мКонтекстВызоваИнструментов.Итерация > МаксВызовов Тогда
		ирОбщий.СообщитьЛкс("Превышен лимит ("+МаксВызовов+") итераций вызова инструментов");
		Возврат Ложь;
	КонецЕсли;
	ОтветыИнструментов = Новый Массив;
	ЛиНапарник = Не СообщениеИИ.Свойство("role");
	Если ЛиНапарник Тогда
		ПредСообщение = УИДСообщения;
	Иначе
		ПредСообщение = СообщениеИИ;
		ПредСообщение.role = "assistant";
	КонецЕсли;
	Для Каждого ВызовИнструмента Из СообщениеИИ.tool_calls Цикл // Структура
		МоментНачала = ТекущаяДата();
		ИмяИнструмента = ВызовИнструмента.function.name;
		Аргументы = ВызовИнструмента.function.arguments;
		ПредставлениеРезультата = "";
		Если Не мЛиВключитьИнструменты Тогда
			ТекстРезультата = "";
		Иначе
			Попытка
				РезультатИнструмента = ВызватьИнструмент(ИмяИнструмента, Аргументы, ПредставлениеРезультата);
				Если РезультатИнструмента = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				Если ТипЗнч(РезультатИнструмента) = Тип("Строка") Тогда
					ТекстРезультата = РезультатИнструмента;
				Иначе
					ТекстРезультата = ирОбщий.ОбъектВТекстЖСОНЛкс(РезультатИнструмента);
				КонецЕсли;
			Исключение
				ТекстРезультата = ирОбщий.СтрШаблонЛкс("Ошибка выполнения %1: %2", ИмяИнструмента, ОписаниеОшибки());
			КонецПопытки;
		КонецЕсли;
		ОтветИнструмента = Неопределено;
		Если ТипЗнч(СообщениеИИ) = Тип("Структура") Тогда
			ЛиОбработанКлиентом = ЗначениеЗаполнено(ТекстРезультата) Или ЗначениеЗаполнено(ПредставлениеРезультата);
			ОтветИнструмента = Новый Структура;
			ОтветИнструмента.Вставить("role", "tool");
			ОтветИнструмента.Вставить("content", ТекстРезультата);
			ОтветИнструмента.Вставить("name", ИмяИнструмента);
			ОтветИнструмента.Вставить("tool_call_id", ирОбщий.СвойствоСтруктурыЛкс(ВызовИнструмента, "id", ""));
			Если ЛиНапарник Тогда
				Если ЗначениеЗаполнено(ТекстРезультата) Тогда
					ОтветИнструмента.Вставить("status", "rejected"); // Для серверного инструмента Напарника указываем что мы выполнили на клиенте
				Иначе
					ОтветИнструмента.content = Неопределено;
					ОтветИнструмента.Вставить("status", "accepted"); // Для серверного инструмента Напарника указываем что мы НЕ выполнили на клиенте
				КонецЕсли;
			Иначе
				Если ПустаяСтрока(ОтветИнструмента.content) Тогда
					ОтветИнструмента.content = ПредставлениеРезультата; // Иначе может переключиться на другой человечий язык
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТипЗнч(СообщениеИИ) = Тип("Массив") И ЗначениеЗаполнено(ТекстРезультата) Тогда
			ОтветИнструмента = Новый Структура;
			ОтветИнструмента.Вставить("Текст", "Я проверил твой ответ инструментом " + ИмяИнструмента + " с результатом: 
			|" + ТекстРезультата);
			ЛиОбработанКлиентом = Истина;
		КонецЕсли;
		Длительность = ТекущаяДата() - МоментНачала;
		ОписаниеДозапроса = НовоеОписаниеДозапроса(Аргументы, ИмяИнструмента, ТекстРезультата, ЛиОбработанКлиентом, ПредставлениеРезультата, Длительность);
		мДозапросы.Добавить(ОписаниеДозапроса);
		Если ОтветИнструмента <> Неопределено Тогда
			ОтветыИнструментов.Добавить(ОтветИнструмента);
		КонецЕсли;
	КонецЦикла;
	Если ОтветыИнструментов.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	//мНакопленныйОтвет = "";
	ОтправитьЗапросИИ(ОтветыИнструментов,,,,, мЛиПотоковый,,,,,,, мЛиВключитьИнструменты, ПредСообщение);
	мКонтекстВызоваИнструментов.Итерация = мКонтекстВызоваИнструментов.Итерация + 1;
	Возврат Истина;
КонецФункции 

Функция ПроверитьБлокКода(Знач ПроверяемыйКод) Экспорт
	Возврат Ложь; // Пока не придумал хорошего способа перезапускать запрос с сохранением контекста
	СтруктураСообщения = Новый Структура;
	ВызовыИнструментов = Новый Массив;
	СтруктураСообщения.Вставить("tool_calls", ВызовыИнструментов);
	Агрументы = Новый Структура("code", ПроверяемыйКод);
	Агрументы = ирОбщий.ОбъектВТекстЖСОНЛкс(Агрументы); // для наглядности отображения в таблице
	ВызовИнструмента = Новый Структура("function", Новый Структура("name, arguments", "mcp__syntax-checker__validate", Агрументы));
	ВызовыИнструментов.Добавить(ВызовИнструмента);
	Возврат ОбработатьВызовыИнструментов(СтруктураСообщения);
КонецФункции

Функция НовоеОписаниеДозапроса(Знач Аргументы, Знач ИмяИнструмента, Знач ТекстРезультата, Знач ЛиОбработанКлиентом, Знач ПредставлениеРезультата, Знач Длительность) Экспорт
	Результат = Новый Структура();
	Результат.Вставить("Функция", ИмяИнструмента);
	Результат.Вставить("Аргументы", Аргументы);
	Результат.Вставить("Результат", ТекстРезультата);
	Результат.Вставить("ОтправленоСимволов", СтрДлина(ТекстРезультата));
	Результат.Вставить("ЛиОбработанКлиентом", ЛиОбработанКлиентом);
	Результат.Вставить("ПредставлениеРезультата", ПредставлениеРезультата);
	Результат.Вставить("Длительность", Длительность);
	Возврат Результат;
КонецФункции

