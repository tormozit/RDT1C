	Данные = ирОбщий.ЗагрузитьЗначениеИзФайлаЛкс(ФайлТокена.ПолноеИмя); // см. ДанныеТокенаОбразец
	Если Ложь
		Или Данные = Неопределено
		Или Не Данные.Свойство("expires_at")
	Тогда
		Возврат Неопределено;
	КонецЕсли;
	ТекущееВремя = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Если ТекущееВремя > Данные.expires_at Тогда
		Возврат ОбновитьТокенКвен(Данные);
	КонецЕсли;
	Возврат Данные;
