Функция ВызватьИнструмент(Знач ИмяИнструмента, Знач Аргументы, ПредставлениеРезультата = "")
	Если мПолеТекстаПрограммы.мПлатформа = Неопределено Тогда
		мПолеТекстаПрограммы.ИнициироватьНеинтерактивно();
	КонецЕсли;
	// Аргументы приходит как Структура (если распарсили) либо как строка JSON
	Если ТипЗнч(Аргументы) = Тип("Строка") И ирОбщий.ЛиТекстJSONЛкс(Аргументы) Тогда
		Аргументы = ирОбщий.ОбъектИзТекстаЖСОНЛкс(Аргументы);
	КонецЕсли;
	Если Аргументы = Неопределено Тогда
		Аргументы = Новый Структура;
	КонецЕсли;
	Если ИмяИнструмента = "platform_list_objects" Тогда
		Возврат Инструмент_ПлатформаСписокОбъектов(Аргументы);
	ИначеЕсли ИмяИнструмента = "platform_object" Тогда
		Возврат Инструмент_ПлатформаОписаниеОбъекта(Аргументы);
	ИначеЕсли ИмяИнструмента = "platform_object_member" Тогда
		Возврат Инструмент_ПлатформаОписаниеСлова(Аргументы);
	ИначеЕсли ИмяИнструмента = "metadata_list_objects" Тогда
		Возврат Инструмент_МетаданныеСписокОбъектов(Аргументы);
	ИначеЕсли ИмяИнструмента = "metadata_list_common_modules" Тогда
		Возврат Инструмент_МетаданныеСписокОбщихМодулей();
	ИначеЕсли ИмяИнструмента = "metadata_object" Тогда
		Возврат Инструмент_МетаданныеОписаниеОбъекта(Аргументы.full_name);
	ИначеЕсли ИмяИнструмента = "metadata_form" Тогда
		Возврат Инструмент_ОписаниеФормы(Аргументы.full_name);
	ИначеЕсли ИмяИнструмента = "module_list_methods" Тогда
		Возврат Инструмент_СписокМетодов(Аргументы);
	ИначеЕсли ИмяИнструмента = "module_method" Тогда
		Возврат Инструмент_ОписаниеМетода(Аргументы);
	// EDT - похоже просто дублирует запущенные на сервере сессии инструментов, чтобы клиент мог показать индикаторы
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "GetProjects", Истина) Тогда
		Возврат ирОбщий.ЗначенияВМассивЛкс(Метаданные.Имя);
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "SearchText", Истина) Тогда
		// {"search_query": "СвернутьМассивЛкс", "file_patterns": "*.bsl"}
		// {"searchText": "СвернутьМассивЛкс", "filePatterns": "**/*.bsl"}
		// {"query": "СвернутьМассивЛкс", "fileMasks": "*.bsl"}
		Если Аргументы.Свойство("searchText") Тогда    
			ПараметрЧтоИскать = Аргументы.searchText;
		ИначеЕсли Аргументы.Свойство("query") Тогда    
			ПараметрЧтоИскать = Аргументы.query;
		Иначе
			ПараметрЧтоИскать = Аргументы.search_query;
		КонецЕсли;
		ПоискВызововМетода = мПолеТекстаПрограммы.ПолучитьФорму("ПоискВМодулях"); // Всегда новая, т.к. при открытии будет подмена основного объекта
		ПоискВызововМетода.ПараметрЧтоИскать = ПараметрЧтоИскать;
		Если ирОбщий.СвойствоСтруктурыЛкс(Аргументы, "refs") = Истина Тогда
			ПоискВызововМетода.ПараметрРежимПоиска = "Ссылки";
		Иначе
			ПоискВызововМетода.ПараметрРежимПоиска = "Точный";
		КонецЕсли;
		//ПоискВызововМетода.ПараметрСтруктураТипаРодителя = СтруктураТипаРодителя;
		//ПоискВызововМетода.ПараметрСтруктураТипаКонтекста = СтруктураТипаКонтекста;
		ПоискВызововМетода.Открыть();
		ПоискВызововМетода.ОбновитьДанные();
		ПоискВызововМетода.Закрыть();
		Результат = ПоискВызововМетода.ВызовыСлова.Выгрузить(, "Модуль, ВызывающийМетод, НомерСтрокиМодуля");
		Если Результат.Количество() > 100 Тогда
			Возврат "Слишком много результатов";
		КонецЕсли;
		Возврат ирОбщий.ТаблицаЗначенийВМассивЛкс(Результат);
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "SearchFiles", Истина) Тогда
		// {"path": ".", "pattern": "*ирОбщий*"}
		Возврат "";
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "FindSimilar_in_Project", Истина) Тогда
		// Аргументы.synthetic_call_key = "Справочник Скидки";
		// Аргументы.synthetic_call_key = "CommonModules.*.СортироватьМассив";
		Возврат "";
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "Task", Истина) Тогда
		Возврат "";
	ИначеЕсли ИмяИнструмента = "mcp__syntax-checker__validate" Тогда
		АнализаторКода = мПолеТекстаПрограммы.КопияКомпоненты();
		АнализаторКода.УстановитьТекст(Аргументы.code,,,,, мПлатформа.ИмяДинамическогоМодуля());
		АнализаторКода.ПроверитьВыраженияТекста(,,,,, Ложь);
		ТаблицаОшибок = АнализаторКода.ОшибкиМодуля.Выгрузить(, "ВыражениеРодитель, Позиция, Слово, ТипОшибки, ТипРодителя");
		Если ТаблицаОшибок.Количество() = 0 Тогда
			ПредставлениеРезультата = "Ошибок не найдено";
			Возврат "";
		ИначеЕсли ТаблицаОшибок.Количество() > 100 Тогда
			Возврат "Слишком много ошибок";
		Иначе
			мНакопленныйОтвет = "";
			ПредставлениеРезультата = ирОбщий.СтрШаблонЛкс("Найдено %1 ошибок, текст очищен", ТаблицаОшибок.Количество());
			Возврат ирОбщий.ТаблицаЗначенийВМассивЛкс(ТаблицаОшибок);
		КонецЕсли;
	ИначеЕсли ИмяИнструмента = "check_patches" Тогда
		Возврат Инструмент_ПроверитьПатчи(Аргументы.text);
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "Search_ITS", Истина) Тогда
		// Аргументы.query = "Методы сортировки массива Сортировать";
		Возврат "";
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "Search_Documentation", Истина) Тогда
		// Аргументы.query = "Методы сортировки массива Сортировать";
		Возврат "";
	Иначе
		//ВызватьИсключение "ИИ запросил неизвестный инструмент: " + ИмяИнструмента;
		Возврат "";
	КонецЕсли;
КонецФункции   

Функция Инструмент_ПроверитьПатчи(ТекстПатчей) Экспорт
	Патчи = ирОбщий.ОбъектИзТекстаЖСОНЛкс(ТекстПатчей);
	Патчи = ирОбщий.ТаблицаЗначенийИзКоллекцииЛкс(Патчи,,,,, Ложь, Ложь,,,);
	//! Патчи.Колонки.Добавить("start");
	//! Патчи.Колонки.Добавить("end");
	//! Патчи.Колонки.Добавить("isInsert");
	Ошибки = Новый Массив;
	Текст = мПолеТекстаПрограммы.мОригинальныйТекст;
	Для Каждого ПатчиЭлемент Из Патчи Цикл
		Если ПатчиЭлемент.start <> Неопределено И ПатчиЭлемент.start <> "" Тогда
			НайтиМаркерБлока(Текст, ПатчиЭлемент.start,, Не ПатчиЭлемент.isInsert, Истина, Ошибки);
		КонецЕсли;
	КонецЦикла;
	Возврат ирОбщий.СтрСоединитьЛкс(Ошибки, Символы.ПС);
КонецФункции

Функция НайтиМаркерБлока(Знач Текст , Знач Маркер, Знач НачальнаяПозиция = 0, Знач ЛиСтрогийКонец = Истина, Знач ТребоватьУникальность = Ложь, Знач Ошибки = Неопределено) Экспорт
	ШаблонМаркера = Маркер;
	ШаблонМаркера = ирОбщий.ТекстДляРегВыраженияЛкс(ШаблонМаркера);
	ШаблонЗаменыНепечатных = "[ \t\n]+";
	ШаблонМаркера = ирОбщий.ЗаменитьРегВыражениеЛкс(ШаблонМаркера, "(\\n|[ \t])+", ШаблонЗаменыНепечатных, Ложь);
	Если ирОбщий.СтрНачинаетсяСЛкс(ШаблонМаркера, ШаблонЗаменыНепечатных) Тогда
		ШаблонМаркера = ирОбщий.ТекстБезПервогоФрагментаЛкс(ШаблонМаркера, ШаблонЗаменыНепечатных);
	КонецЕсли;
	Если ирОбщий.СтрКончаетсяНаЛкс(ШаблонМаркера, ШаблонЗаменыНепечатных) Тогда
		ШаблонМаркера = ирОбщий.ТекстБезПоследнегоФрагментаЛкс(ШаблонМаркера, ШаблонЗаменыНепечатных);
	КонецЕсли;
	ШаблонМаркера = "^[ \t]*" + ШаблонМаркера;
	Если ЛиСтрогийКонец Тогда
		ШаблонМаркера = ШаблонМаркера + "[ |\t]*$";
	КонецЕсли;
	Вхождение = ирОбщий.НайтиРегВыражениеЛкс(Сред(Текст, НачальнаяПозиция + 1), ШаблонМаркера,, ТребоватьУникальность,, Истина, Ложь);
	Если Вхождение.Количество() = 1 Тогда
		Вхождение = Вхождение[0];
	ИначеЕсли Вхождение.Количество() > 1 Тогда
		Если ТребоватьУникальность Тогда
			ТекстСообщения = "Найдены дубли маркера: " + ирОбщий.ПредставлениеСОбрезкойДлиныЛкс(СокрЛП(Маркер), 100);
			Если Ошибки <> Неопределено Тогда
				Ошибки.Добавить(ТекстСообщения);
			Иначе
				ирОбщий.СообщитьЛкс(ТекстСообщения);
			КонецЕсли;
			Возврат Неопределено;
		КонецЕсли;
		Вхождение = Вхождение[0];
	Иначе
		ТекстСообщения = "Не удалось найти маркер: " + ирОбщий.ПредставлениеСОбрезкойДлиныЛкс(СокрЛП(Маркер), 100);
		Если Ошибки <> Неопределено Тогда
			Ошибки.Добавить(ТекстСообщения);
		Иначе
			ирОбщий.СообщитьЛкс(ТекстСообщения);
		КонецЕсли;
		Возврат Неопределено;
	КонецЕсли;
	Возврат Вхождение;
КонецФункции   

