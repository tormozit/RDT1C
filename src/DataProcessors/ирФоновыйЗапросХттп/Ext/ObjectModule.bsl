// Генерирует случайный code_verifier (строка из 43-128 символов)
// Используется для OAuth2 PKCE flow
Функция СгенерироватьКодПроверки() Экспорт
	// code_verifier должен быть длиной от 43 до 128 символов
	// Генерируем 64 случайных символа из безопасного набора
	Длина = 64;
	РазрешенныеСимволы = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~";
	Результат = "";
	Генератор = Новый ГенераторСлучайныхЧисел();
	Для Номер = 1 По Длина Цикл
		СлучайныйИндекс = Генератор.СлучайноеЧисло(0, СтрДлина(РазрешенныеСимволы) - 1);
		Результат = Результат + Сред(РазрешенныеСимволы, СлучайныйИндекс + 1, 1);
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Вычисляет code_challenge из code_verifier по методу S256
// code_challenge = base64url(SHA256(code_verifier))
Функция СгенерироватьКодГонки(Знач КодПроверки) Экспорт
	Хеш = ирОбщий.ХешЛкс(КодПроверки,, Вычислить("ХешФункция").SHA256, Истина);
	Base64Строка = Вычислить("ПолучитьBase64СтрокуИзДвоичныхДанных(Хеш)");
	Base64Url = СтрЗаменить(Base64Строка, "+", "-");
	Base64Url = СтрЗаменить(Base64Url, "/", "_");
	Base64Url = СтрЗаменить(Base64Url, "=", "");
	Возврат Base64Url;
КонецФункции

