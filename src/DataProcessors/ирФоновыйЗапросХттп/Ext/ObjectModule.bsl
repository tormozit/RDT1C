Процедура АвторизоватьсяВКвен() Экспорт
	CodeVerifier = СгенерироватьКодПроверки();
	CodeChallenge = СгенерироватьКодГонки(CodeVerifier);
	СохранитьКодПроверки(CodeVerifier);
	Тело = "client_id="+ИДКлиентаКВЕН()+
		"&scope=openid%20profile%20email%20model.completion" +
		"&code_challenge_method=S256" +
		"&code_challenge=" + CodeChallenge;
	HTTPСоединение = ирОбщий.СоединениеHTTPЛкс("chat.qwen.ai",,,,,, Истина);
	HTTPОтвет = ЗапроситьКвенТокен(HTTPСоединение, "device/code", Тело);
	Если Не ирОбщий.ЛиУспешныйОтветHTTPЛкс(HTTPОтвет) Тогда
		Сообщить("Ошибка начала авторизации: " + HTTPОтвет.ПолучитьТелоКакСтроку());
		Возврат;
	КонецЕсли;
	Данные = ирОбщий.ОбъектИзТекстаЖСОНЛкс(HTTPОтвет.ПолучитьТелоКакСтроку());
	ЗапуститьПриложение(Данные.verification_uri_complete);
	Сообщить("Выполните авторизацию в открывшемся браузере на сайте Qwen");
	DeviceCode = Данные.device_code;
	ИнтервалСекунд = 3;
	МаксОжидание = 10; // Максимум 10 секунд
	ПрошлоСекунд = 0;
	Успех = Ложь;
	Индикатор = ирОбщий.ПолучитьИндикаторПроцессаЛкс(, "Ждем авторизации через Браузер");
	Пока ПрошлоСекунд < МаксОжидание Цикл
		ирОбщий.ОбработатьИндикаторЛкс(Индикатор);
		ирОбщий.ПаузаЛкс(ИнтервалСекунд);
		ПрошлоСекунд = ПрошлоСекунд + ИнтервалСекунд;
		Тело = "client_id="+ИДКлиентаКВЕН()+
			"&device_code=" + DeviceCode +
			"&grant_type=urn:ietf:params:oauth:grant-type:device_code" +
			"&code_verifier=" + ВосстановитьКодПроверки();
		HTTPОтвет = ЗапроситьКвенТокен(HTTPСоединение, "token", Тело);
		Если ирОбщий.ЛиУспешныйОтветHTTPЛкс(HTTPОтвет) Тогда
			НовыеДанные = ирОбщий.ОбъектИзТекстаЖСОНЛкс(HTTPОтвет.ПолучитьТелоКакСтроку());
			СохранитьТокенКВЕН(НовыеДанные);
			Успех = Истина;
			Прервать;
		Иначе
			ТекстОшибки = HTTPОтвет.ПолучитьТелоКакСтроку();
			Если Найти(ТекстОшибки, "authorization_pending") Тогда
				Продолжить;
			ИначеЕсли Найти(ТекстОшибки, "slow_down") Тогда
				ИнтервалСекунд = ИнтервалСекунд + 1;
				Продолжить;
			ИначеЕсли Найти(ТекстОшибки, "expired_token") Тогда
				Сообщить("Время ожидания авторизации истекло");
				Прервать;
			Иначе
				Сообщить("Ошибка авторизации: " + ТекстОшибки);
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если Успех Тогда
		Сообщить("Авторизация Qwen выполнена!");
	Иначе
		Сообщить("Авторизация Qwen НЕ выполнена.");
	КонецЕсли;
КонецПроцедуры

Функция ЗапроситьКвенТокен(Знач HTTPСоединение, Знач АдресРесурса, Знач Тело) Экспорт
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/x-www-form-urlencoded");
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1/oauth2/"+ АдресРесурса);
	HTTPЗапрос.Заголовки = Заголовки;
	HTTPЗапрос.УстановитьТелоИзСтроки(Тело);
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	Возврат HTTPОтвет;
