Функция ОбновитьТокенКвен(Знач ДанныеТокена) Экспорт
	Если НЕ ДанныеТокена.Свойство("refresh_token") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Тело = "client_id="+ИДКлиентаКВЕН()+
		"&grant_type=refresh_token" +
		"&refresh_token=" + ДанныеТокена.refresh_token;
	HTTPСоединение = ирОбщий.СоединениеHTTPЛкс("chat.qwen.ai",,,,,, Истина);
	HTTPОтвет = ЗапроситьКвенТокен(HTTPСоединение, "token", Тело);
	Если ирОбщий.ЛиУспешныйОтветHTTPЛкс(HTTPОтвет) Тогда
		ТекстОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		НовыеДанные = ирОбщий.ОбъектИзТекстаЖСОНЛкс(ТекстОтвета);
		СохранитьТокенКВЕН(НовыеДанные);
		Возврат НовыеДанные;
	КонецЕсли;
	Возврат Неопределено;
