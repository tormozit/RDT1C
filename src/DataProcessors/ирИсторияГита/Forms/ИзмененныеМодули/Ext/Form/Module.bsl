Процедура ПапкаГитаОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ЗапуститьПриложение(Элемент.Значение);
КонецПроцедуры

Процедура ИзмененныеМодулиПриАктивизацииСтроки(Элемент = Неопределено)
	Элемент = ЭлементыФормы.ИзмененныеМодули;
	ирКлиент.ТабличноеПолеПриАктивизацииСтрокиЛкс(ЭтаФорма, Элемент);
	Если Элемент.ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ЗначениеЗаполнено(Элемент.ТекущаяСтрока.ДатаИзмененияКэша) Тогда
		мИсторияГита.ОтображатьКонцыСтрок = ОтображатьКонцыСтрок;
		мИсторияГита.ЧислоСтрокКонтекста = ЧислоСтрокКонтекста;
		мИсторияГита.ТекстИзмененийФайла = ирОбщий.ВыполнитьКомандуОСЛкс(НачалоКомандыГита() + "diff --no-index --no-prefix " + мИсторияГита.ПараметрыВыводаИзмененийДляКоманды()
			+ " """ + ЭлементыФормы.ИзмененныеМодули.ТекущаяСтрока.ФайлГита + """ """ + Элемент.ТекущаяСтрока.ФайлКэша + """",,,,, КодировкаТекста.UTF8,, Не ОтображатьКонцыСтрок);
		мИсторияГита.ТекстИзмененийФайла = "@@" + ирОбщий.ТекстБезПервогоФрагментаЛкс(мИсторияГита.ТекстИзмененийФайла, "@@");
		ТекстКэшаМодуля = ирОбщий.ПрочитатьТекстИзФайлаЛкс(Элемент.ТекущаяСтрока.ФайлКэша);
	Иначе
		мИсторияГита.ТекстИзмененийФайла = "";
		ТекстКэшаМодуля = "";
	КонецЕсли;
	Если Истина
		И ПараметрИмяМодуля = Элемент.ТекущаяСтрока.Модуль
		И мНачальнаяСтрока > 0
	Тогда
		мИсторияГита.ПараметрНомерСтроки = мНачальнаяСтрока;
	КонецЕсли;
	мИсторияГита.ОбновитьПоискВТекстеФайла(, Истина, ТекстКэшаМодуля);
	мИсторияГита.АктивироватьБлокИзТекста(ЭлементыФормы.СтруктураОтличий);
КонецПроцедуры

Процедура ДействияФормыОбновить(Кнопка)
	ОбновитьДанные();
КонецПроцедуры

