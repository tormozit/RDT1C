	ОформлениеСтроки.Ячейки.ФайлКэша.УстановитьТекст("<Открыть>");
	ирКлиент.ТабличноеПолеПриВыводеСтрокиЛкс(ЭтаФорма, Элемент, ОформлениеСтроки, ДанныеСтроки);
